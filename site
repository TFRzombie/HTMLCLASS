<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>HMSCLASS</title>
<meta name="description" content="HMSCLASS - Watch videos privately"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --accent:#6366f1;
  --accent2:#8b5cf6;
  --accent3:#06b6d4;
  --bg:#0d0f1a;
  --bg2:#141626;
  --bg3:#1c1f35;
  --bg4:#242840;
  --card:#181b2e;
  --border:rgba(99,102,241,0.18);
  --border2:rgba(99,102,241,0.35);
  --text:#e8eaf6;
  --text2:#9ba3c7;
  --text3:#6b7299;
  --glow:0 0 24px rgba(99,102,241,0.25);
  --glow2:0 0 40px rgba(139,92,246,0.3);
  --shadow:0 8px 32px rgba(0,0,0,0.4);
  --shadow-card:0 4px 20px rgba(0,0,0,0.3);
  --shadow-hover:0 12px 40px rgba(99,102,241,0.25);
  --r:14px;
  --r2:10px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px;}
::-webkit-scrollbar-thumb:hover{background:var(--accent);}

/* ── HEADER ── */
.header{background:var(--bg2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:1000;backdrop-filter:blur(12px);}
.header-content{max-width:1300px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;gap:1.25rem;}
.logo-section{display:flex;align-items:center;gap:0.6rem;cursor:pointer;flex-shrink:0;text-decoration:none;}
.logo-badge{width:38px;height:38px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:var(--glow);}
.logo-text{font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,#a5b4fc,#c4b5fd,var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-0.02em;}

/* ── SEARCH ── */
.search-container{flex:1;max-width:580px;position:relative;margin:0 auto;}
.search-row{display:flex;align-items:center;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:border-color 0.2s,box-shadow 0.2s;}
.search-row:focus-within{border-color:var(--accent);box-shadow:var(--glow);}
.search-input{flex:1;padding:0.7rem 1rem;font-size:0.97rem;border:none;background:transparent;color:var(--text);outline:none;}
.search-input::placeholder{color:var(--text3);}
.search-type-select{background:transparent;border:none;border-left:1px solid var(--border);color:var(--text2);font-size:0.82rem;padding:0 0.6rem;height:100%;cursor:pointer;outline:none;min-width:80px;}
.search-type-select option{background:var(--bg3);color:var(--text);}
.settings-trigger{width:40px;height:100%;background:transparent;border:none;border-left:1px solid var(--border);color:var(--text2);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:color 0.2s;}
.settings-trigger:hover{color:var(--accent);}
.search-go{width:44px;height:100%;background:var(--accent);border:none;color:white;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background 0.2s;}
.search-go:hover{background:var(--accent2);}

/* ── SETTINGS POPUP ── */
.search-settings-popup{display:none;position:absolute;top:calc(100% + 8px);right:0;background:var(--bg3);border:1px solid var(--border2);padding:1.1rem;border-radius:var(--r);box-shadow:var(--shadow);z-index:2000;min-width:220px;flex-direction:column;gap:0.85rem;}
.search-settings-popup.open{display:flex;}
.settings-group{display:flex;flex-direction:column;gap:0.4rem;}
.settings-label{font-size:0.72rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.07em;}
.search-dropdown{background:var(--bg4);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:0.45rem 0.6rem;font-size:0.88rem;outline:none;width:100%;}
.search-dropdown:focus{border-color:var(--accent);}
.search-dropdown option{background:var(--bg4);}

/* ── RECENT SEARCHES ── */
.recent-searches{display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r);box-shadow:var(--shadow);z-index:1001;flex-direction:column;overflow:hidden;}
.recent-searches.open{display:flex;}
.search-item{padding:9px 14px;cursor:pointer;display:flex;align-items:center;gap:9px;transition:background 0.15s;color:var(--text);font-size:0.9rem;}
.search-item:hover{background:var(--bg4);}
.search-item-icon{font-size:0.75rem;opacity:0.5;}
.rs-label{padding:7px 14px 4px;font-size:0.7rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;}

/* ── HEADER ACTIONS ── */
.header-actions{display:flex;align-items:center;gap:0.5rem;flex-shrink:0;margin-left:auto;}
.hbtn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:0.5rem 0.9rem;border-radius:var(--r2);font-size:0.85rem;font-weight:600;cursor:pointer;transition:all 0.2s;display:inline-flex;align-items:center;gap:0.35rem;white-space:nowrap;}
.hbtn:hover{background:var(--bg4);border-color:var(--accent);color:var(--text);}
.hbtn.active{background:linear-gradient(135deg,var(--accent),var(--accent2));border-color:transparent;color:white;box-shadow:var(--glow);}

/* ── NAV TABS ── */
.nav-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 1.25rem;}
.nav-bar-inner{max-width:1300px;margin:0 auto;display:flex;gap:0;}
.nav-tab{padding:0.65rem 1.1rem;font-size:0.88rem;font-weight:600;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;display:flex;align-items:center;gap:0.4rem;background:none;border-top:none;border-left:none;border-right:none;}
.nav-tab:hover{color:var(--text);}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent);}

/* ── MAIN ── */
.main-content{max-width:1300px;margin:0 auto;padding:1.75rem 1.25rem;}

/* ── WELCOME HERO ── */
.hero{text-align:center;padding:4rem 1rem 3rem;}
.hero-glow{width:80px;height:80px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2.2rem;box-shadow:var(--glow2),0 0 80px rgba(99,102,241,0.15);}
.hero-title{font-size:2.4rem;font-weight:900;background:linear-gradient(135deg,#a5b4fc,#c4b5fd,#67e8f9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-0.03em;margin-bottom:0.6rem;}
.hero-sub{font-size:1rem;color:var(--text2);margin-bottom:2.5rem;}
.quick-searches{display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;max-width:600px;margin:0 auto;}
.quick-chip{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:0.4rem 0.9rem;border-radius:20px;font-size:0.83rem;cursor:pointer;transition:all 0.2s;}
.quick-chip:hover{background:var(--accent);border-color:var(--accent);color:white;}

/* ── SECTION HEADER ── */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;}
.section-title{font-size:1.15rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:0.5rem;}
.section-badge{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:20px;letter-spacing:0.04em;}

/* ── VIDEO GRID ── */
.video-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:1.25rem;}
.video-card,.playlist-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);cursor:pointer;transition:all 0.25s;overflow:hidden;position:relative;}
.video-card:hover,.playlist-card:hover{transform:translateY(-4px);border-color:var(--border2);box-shadow:var(--shadow-hover);}
.video-thumbnail,.playlist-thumbnail{position:relative;width:100%;aspect-ratio:16/9;overflow:hidden;background:#0a0c18;}
.video-thumbnail img,.playlist-thumbnail img{width:100%;height:100%;object-fit:cover;transition:transform 0.35s;}
.video-card:hover .video-thumbnail img,.playlist-card:hover .playlist-thumbnail img{transform:scale(1.06);}
.play-overlay{position:absolute;inset:0;background:rgba(0,0,0,0);display:flex;align-items:center;justify-content:center;transition:all 0.25s;}
.play-btn-circle{width:48px;height:48px;background:rgba(99,102,241,0.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;opacity:0;transform:scale(0.7);transition:all 0.25s;backdrop-filter:blur(4px);}
.video-card:hover .play-overlay,.playlist-card:hover .play-overlay{background:rgba(0,0,0,0.3);}
.video-card:hover .play-btn-circle,.playlist-card:hover .play-btn-circle{opacity:1;transform:scale(1);}
.video-duration{position:absolute;bottom:7px;right:7px;background:rgba(0,0,0,0.85);color:white;padding:2px 7px;border-radius:5px;font-size:0.72rem;font-weight:600;letter-spacing:0.02em;}
.playlist-badge{position:absolute;bottom:7px;right:7px;background:rgba(99,102,241,0.9);color:white;padding:3px 8px;border-radius:5px;font-size:0.72rem;font-weight:700;}
.trending-rank{position:absolute;top:8px;left:8px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:800;box-shadow:0 2px 8px rgba(99,102,241,0.4);}
.video-info,.playlist-info{padding:0.85rem;}
.video-title,.playlist-title{font-weight:600;margin-bottom:0.35rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-size:0.9rem;color:var(--text);transition:color 0.2s;line-height:1.4;}
.video-card:hover .video-title,.playlist-card:hover .playlist-title{color:#a5b4fc;}
.video-channel,.playlist-meta{color:var(--text2);font-size:0.8rem;margin-bottom:0.3rem;}
.video-meta{display:flex;justify-content:space-between;align-items:center;font-size:0.75rem;color:var(--text3);}
.channel-card-inner{display:flex;align-items:center;gap:0.85rem;padding:1rem;}
.channel-avatar-sm{width:52px;height:52px;border-radius:50%;object-fit:cover;border:2px solid var(--border2);}
.channel-card-info{flex:1;min-width:0;}
.channel-card-name{font-weight:700;font-size:0.92rem;color:var(--text);margin-bottom:0.15rem;}
.channel-card-desc{font-size:0.78rem;color:var(--text2);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}

/* ── LOAD MORE ── */
.load-more-wrap{text-align:center;margin-top:2rem;}
.load-more-btn{background:var(--bg3);border:1px solid var(--border2);color:var(--accent);padding:0.65rem 2.5rem;border-radius:var(--r2);font-size:0.9rem;font-weight:600;cursor:pointer;transition:all 0.2s;}
.load-more-btn:hover{background:var(--accent);color:white;border-color:var(--accent);box-shadow:var(--glow);}

/* ── LOADING ── */
.loading{text-align:center;padding:4rem 0;}
.loading-spinner{width:36px;height:36px;border:3px solid var(--bg4);border-top:3px solid var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 1rem;}
.loading-text{color:var(--text2);font-size:0.9rem;}
@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}

/* ── MODAL ── */
.modal{position:fixed;inset:0;background:rgba(0,0,0,0.88);display:flex;align-items:center;justify-content:center;z-index:2000;padding:1rem;backdrop-filter:blur(6px);}
.modal-content{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--r);width:1040px;max-width:min(96vw,118vh);max-height:92vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,0.6),var(--glow);}
.modal-header{display:flex;align-items:center;padding:0.6rem 0.85rem;gap:0.4rem;border-bottom:1px solid var(--border);}
.modal-video-title{font-size:0.85rem;font-weight:600;color:var(--text);max-width:340px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-right:auto;}
.modal-actions{display:flex;gap:0.25rem;align-items:center;}
.mbtn{background:none;border:1px solid transparent;font-size:0.82rem;cursor:pointer;padding:0.3rem 0.6rem;border-radius:7px;transition:all 0.2s;color:var(--text2);white-space:nowrap;display:flex;align-items:center;gap:0.3rem;}
.mbtn:hover{background:var(--bg3);border-color:var(--border);color:var(--text);}
.modal-close{background:transparent;border:1px solid transparent;font-size:1.1rem;cursor:pointer;color:var(--text3);padding:5px 8px;border-radius:7px;transition:all 0.2s;}
.modal-close:hover{background:var(--bg3);border-color:var(--border);color:var(--text);}
.video-player-container{padding:0.85rem;display:flex;gap:1rem;width:100%;box-sizing:border-box;}
.video-player{position:relative;flex:1;min-width:0;}
.video-player-inner{position:relative;width:100%;padding-top:56.25%;}
.video-iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:var(--r2);background:#000;}

/* ── PLAYLIST SIDEBAR ── */
.playlist-sidebar{width:280px;flex-shrink:0;background:var(--bg3);border-radius:var(--r2);padding:0.75rem;display:flex;flex-direction:column;gap:0.5rem;max-height:520px;overflow-y:auto;}
.playlist-sidebar-header{display:flex;gap:0.4rem;flex-wrap:wrap;}
.psb-btn{flex:1;border:1px solid var(--border2);padding:5px 8px;border-radius:7px;font-size:0.75rem;font-weight:700;cursor:pointer;transition:all 0.2s;background:var(--bg4);color:var(--text2);}
.psb-btn:hover,.psb-btn.active{background:var(--accent);border-color:var(--accent);color:white;}
#playlistVideos{display:flex;flex-direction:column;gap:0.35rem;}
.playlist-video-item{display:flex;gap:0.5rem;padding:0.4rem;border-radius:8px;cursor:pointer;transition:background 0.15s;border:1px solid var(--border);}
.playlist-video-item:hover{background:var(--bg4);}
.playlist-video-item.active{background:rgba(99,102,241,0.15);border-color:var(--accent);}
.playlist-video-thumb{width:76px;height:43px;object-fit:cover;border-radius:5px;flex-shrink:0;}
.playlist-video-info{flex:1;min-width:0;}
.playlist-video-title{font-size:0.78rem;font-weight:500;color:var(--text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:2px;}
.playlist-video-channel{font-size:0.68rem;color:var(--text3);}
#playlistLoadingSpinner{display:none;align-items:center;justify-content:center;gap:0.5rem;padding:1rem;color:var(--text2);font-size:0.82rem;}

/* ── UPDATE POPUP ── */
.update-modal{position:fixed;inset:0;background:rgba(0,0,0,0.8);display:flex;align-items:center;justify-content:center;z-index:3000;backdrop-filter:blur(8px);}
.update-modal-content{background:var(--bg2);border:1px solid var(--border2);padding:2.5rem;border-radius:20px;max-width:460px;width:90%;text-align:center;box-shadow:0 24px 80px rgba(0,0,0,0.5),var(--glow2);animation:popUp 0.35s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes popUp{from{transform:scale(0.85);opacity:0}to{transform:scale(1);opacity:1}}
.update-icon{font-size:3.5rem;margin-bottom:1rem;display:block;animation:bounce 2s infinite;}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.update-title{font-size:1.6rem;font-weight:900;background:linear-gradient(135deg,#a5b4fc,#c4b5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:0.6rem;}
.update-text{color:var(--text2);font-size:0.92rem;line-height:1.65;margin-bottom:1.75rem;}
.update-btn{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;padding:0.85rem 2.5rem;border-radius:var(--r2);font-size:1rem;font-weight:800;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s;box-shadow:var(--glow);}
.update-btn:hover{transform:translateY(-2px);box-shadow:var(--glow2);}

/* ── TRENDING PILLS ── */
.trending-filter{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.25rem;}
.t-pill{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:0.38rem 0.9rem;border-radius:20px;font-size:0.82rem;font-weight:600;cursor:pointer;transition:all 0.2s;}
.t-pill:hover{border-color:var(--accent);color:var(--accent);}
.t-pill.active{background:var(--accent);border-color:var(--accent);color:white;box-shadow:var(--glow);}

/* ── MOBILE ── */
@media(max-width:760px){
  .header-content{flex-wrap:wrap;gap:0.6rem;}
  .search-container{order:3;max-width:100%;flex:0 0 100%;}
  .header-actions{margin-left:auto;}
  .hbtn span{display:none;}
  .nav-tab span{display:none;}
  .video-grid{grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:1rem;}
  .video-player-container{flex-direction:column;}
  .playlist-sidebar{width:100%;max-height:240px;}
  .modal-video-title{max-width:160px;}
}
</style>
</head>
<body>

<!-- Welcome Popup -->
<div id="updatePopup" class="update-modal" style="display:none;">
  <div class="update-modal-content">
    <span class="update-icon">🎓</span>
    <h2 class="update-title">Welcome to HMSCLASS</h2>
    <p class="update-text">Search and watch YouTube videos privately — no tracking, no ads, no blocked content. Trending page, playlist support, and more. Stay lowkey 🤫</p>
    <button class="update-btn" onclick="closeUpdatePopup()">Let's Go →</button>
  </div>
</div>

<!-- Video Modal -->
<div id="videoModal" class="modal" style="display:none;" onclick="modalBackdropClick(event)">
  <div class="modal-content" onclick="event.stopPropagation()">
    <div class="modal-header">
      <span class="modal-video-title" id="modalVideoTitle"></span>
      <div class="modal-actions">
        <button class="mbtn" onclick="fixWhiteScreen()" title="White screen? Click to fix">❓ Fix</button>
        <button class="mbtn" onclick="copyVideoUrl()" id="copyUrlBtn">🔗 Copy URL</button>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="video-player-container" id="videoPlayerContainer">
      <div class="video-player">
        <div class="video-player-inner">
          <iframe id="videoIframe" class="video-iframe" allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Header -->
<header class="header">
  <div class="header-content">
    <div class="logo-section" onclick="goHome()">
      <div class="logo-badge">🎓</div>
      <span class="logo-text">HMSCLASS</span>
    </div>

    <div class="search-container">
      <div class="search-row">
        <input type="text" class="search-input" id="searchInput"
          placeholder="Search videos, channels, playlists..."
          onkeypress="handleKeyPress(event)"
          onfocus="showRecentSearches()"
          onblur="hideRecentSearches()"/>
        <select class="search-type-select" id="searchTypeSelect" onchange="updateSearchPlaceholder()">
          <option value="video">Videos</option>
          <option value="channel">Channels</option>
          <option value="playlist">Playlists</option>
        </select>
        <button class="settings-trigger" onclick="toggleSearchSettings(event)" title="Search options">⚙️</button>
        <button class="search-go" onclick="triggerSearch()">🔍</button>
      </div>
      <div id="searchSettingsPopup" class="search-settings-popup">
        <div class="settings-group">
          <label class="settings-label">Sort By</label>
          <select id="sortSelect" class="search-dropdown">
            <option value="relevance">Relevance</option>
            <option value="date">Upload Date</option>
            <option value="viewCount">View Count</option>
            <option value="rating">Rating</option>
          </select>
        </div>
      </div>
      <div id="recentSearches" class="recent-searches"></div>
    </div>

    <div class="header-actions">
      <button class="hbtn" id="darkBtn" onclick="toggleDarkMode()">🌙</button>
      <button class="hbtn" onclick="promptAndImport()">➕ <span>Import</span></button>
    </div>
  </div>
</header>

<!-- Nav Tabs -->
<nav class="nav-bar">
  <div class="nav-bar-inner">
    <button class="nav-tab active" id="tab-home" onclick="showTab('home')">🏠 <span>Home</span></button>
    <button class="nav-tab" id="tab-trending" onclick="showTab('trending')">🔥 <span>Trending</span></button>
    <button class="nav-tab" id="tab-search" id="tab-search" style="display:none;" onclick="showTab('search')">🔎 <span>Results</span></button>
  </div>
</nav>

<!-- Main -->
<div class="main-content" id="mainContent">

  <!-- HOME TAB -->
  <div id="tab-home-content">
    <div class="hero" id="heroSection">
      <div class="hero-glow">▶</div>
      <h1 class="hero-title">HMSCLASS</h1>
      <p class="hero-sub">Private YouTube watching — no cookies, no tracking, no blocks.</p>
      <div class="quick-searches">
        <span class="quick-chip" onclick="quickSearch('minecraft')">⛏️ Minecraft</span>
        <span class="quick-chip" onclick="quickSearch('music mix')">🎵 Music</span>
        <span class="quick-chip" onclick="quickSearch('funny moments')">😂 Funny</span>
        <span class="quick-chip" onclick="quickSearch('gorilla tag')">🦍 Gorilla Tag</span>
        <span class="quick-chip" onclick="quickSearch('lofi hip hop')">🎧 Lo-Fi</span>
        <span class="quick-chip" onclick="quickSearch('speed runs')">⚡ Speedruns</span>
        <span class="quick-chip" onclick="quickSearch('anime')">🎌 Anime</span>
        <span class="quick-chip" onclick="quickSearch('short films')">🎬 Short Films</span>
      </div>
    </div>
  </div>

  <!-- TRENDING TAB -->
  <div id="tab-trending-content" style="display:none;">
    <div class="section-header">
      <div class="section-title">🔥 Trending <span class="section-badge">LIVE</span></div>
    </div>
    <div class="trending-filter">
      <button class="t-pill active" onclick="loadTrending('','all')">All</button>
      <button class="t-pill" onclick="loadTrending('10','music')">🎵 Music</button>
      <button class="t-pill" onclick="loadTrending('20','gaming')">🎮 Gaming</button>
      <button class="t-pill" onclick="loadTrending('17','film')">🎬 Film & TV</button>
    </div>
    <div class="loading" id="trendingLoading" style="display:none;">
      <div class="loading-spinner"></div>
      <p class="loading-text">Loading trending...</p>
    </div>
    <div class="video-grid" id="trendingGrid"></div>
  </div>

  <!-- SEARCH RESULTS TAB -->
  <div id="tab-search-content" style="display:none;">
    <div class="loading" id="searchLoading" style="display:none;">
      <div class="loading-spinner"></div>
      <p class="loading-text">Searching...</p>
    </div>
    <div id="searchResultsInner">
      <div class="section-header" id="searchResultsHeader" style="display:none;">
        <div class="section-title" id="searchResultsTitle"></div>
      </div>
      <div class="video-grid" id="videoGrid"></div>
      <div class="load-more-wrap" id="loadMoreWrap" style="display:none;">
        <button class="load-more-btn" onclick="loadMore()">Load More</button>
      </div>
    </div>
  </div>

</div>

<script>
const API_KEYS=[
  "AIzaSyB0asSfppFrdLhe6v4LRkpilHvOTzZ9sF4",
  "AIzaSyCBieFCuVzGBb3HFzEpvkMO8OeEGjEX7p0",
  "AIzaSyAGi7dFGAaOyR7MifSM3nORr7M0xJkmLyw"
];
let _aki=0;
function gak(){return API_KEYS[_aki%API_KEYS.length];}
function nextKey(){_aki++;return gak();}

let currentQuery="",currentType="video",currentSort="relevance";
let nextPageToken="",currentVideoId="",currentVideoTitle="";
let playlistVideos=[],currentPlaylistIndex=0,autoplayOn=true;
let recentSearches=JSON.parse(localStorage.getItem("hms_recent")||"[]");
let currentTab="home";
let trendingLoaded=false;

// ── INIT ──
window.onload=()=>{
  const shown=localStorage.getItem("hms_popup");
  if(!shown){document.getElementById("updatePopup").style.display="flex";}
  const dm=localStorage.getItem("hms_dark");
  if(dm==="false"){document.body.style.filter="";/* stays dark by default */}
};

function closeUpdatePopup(){
  document.getElementById("updatePopup").style.display="none";
  localStorage.setItem("hms_popup","1");
}

// ── TABS ──
function showTab(tab){
  ["home","trending","search"].forEach(t=>{
    document.getElementById("tab-"+t+"-content").style.display="none";
    document.getElementById("tab-"+t)?.classList.remove("active");
  });
  document.getElementById("tab-"+tab+"-content").style.display="block";
  document.getElementById("tab-"+tab)?.classList.add("active");
  currentTab=tab;
  if(tab==="trending"&&!trendingLoaded){loadTrending("","all");}
  // show search tab in nav only if it has content
  if(tab==="search"){document.getElementById("tab-search").style.display="flex";}
}

// ── DARK MODE (always dark, just toggles a slight tint) ──
let lightMode=false;
function toggleDarkMode(){
  lightMode=!lightMode;
  document.body.style.filter=lightMode?"invert(1) hue-rotate(180deg)":"";
  document.getElementById("darkBtn").textContent=lightMode?"🌑":"🌙";
}

// ── SEARCH ──
function handleKeyPress(e){if(e.key==="Enter")triggerSearch();}
function updateSearchPlaceholder(){
  const t=document.getElementById("searchTypeSelect").value;
  document.getElementById("searchInput").placeholder=
    t==="channel"?"Search channels...":t==="playlist"?"Search playlists...":"Search videos, channels, playlists...";
}
function toggleSearchSettings(e){
  e.stopPropagation();
  document.getElementById("searchSettingsPopup").classList.toggle("open");
}
document.addEventListener("click",()=>document.getElementById("searchSettingsPopup").classList.remove("open"));

function triggerSearch(){
  const q=document.getElementById("searchInput").value.trim();
  if(!q)return;
  currentQuery=q;
  currentType=document.getElementById("searchTypeSelect").value;
  currentSort=document.getElementById("sortSelect").value;
  nextPageToken="";
  saveRecentSearch(q);
  performSearch(true);
}

function quickSearch(q){
  document.getElementById("searchInput").value=q;
  currentQuery=q;currentType="video";currentSort="relevance";nextPageToken="";
  saveRecentSearch(q);
  performSearch(true);
}

async function performSearch(clear=true){
  showTab("search");
  document.getElementById("searchLoading").style.display="block";
  document.getElementById("searchResultsInner").style.display="none";
  if(clear){document.getElementById("videoGrid").innerHTML="";nextPageToken="";}
  try{
    let url=`https://www.googleapis.com/youtube/v3/search?part=snippet&q=${encodeURIComponent(currentQuery)}&type=${currentType}&maxResults=20&order=${currentSort}&key=${gak()}`;
    if(nextPageToken)url+=`&pageToken=${nextPageToken}`;
    if(currentType==="video")url+="&videoEmbeddable=true";
    const data=await fetchJSON(url);
    nextPageToken=data.nextPageToken||"";
    renderSearchResults(data.items,clear);
  }catch(e){
    nextKey();
    showSearchError("Search failed. Try again. ("+e.message+")");
  }
  document.getElementById("searchLoading").style.display="none";
  document.getElementById("searchResultsInner").style.display="block";
}

function renderSearchResults(items,clear){
  const grid=document.getElementById("videoGrid");
  if(clear)grid.innerHTML="";
  const hdr=document.getElementById("searchResultsHeader");
  const ttl=document.getElementById("searchResultsTitle");
  hdr.style.display="flex";
  if(clear)ttl.innerHTML=`Results for <em style="color:var(--accent);font-style:normal;">"${escHtml(currentQuery)}"</em>`;
  items.forEach(item=>{
    const kind=item.id.kind;
    if(kind==="youtube#video")grid.appendChild(makeVideoCard(item));
    else if(kind==="youtube#playlist")grid.appendChild(makePlaylistCard(item));
    else if(kind==="youtube#channel")grid.appendChild(makeChannelCard(item));
  });
  document.getElementById("loadMoreWrap").style.display=nextPageToken?"block":"none";
}

async function loadMore(){
  if(!nextPageToken)return;
  await performSearch(false);
}

// ── TRENDING ──
let currentTrendingCategory="";
async function loadTrending(categoryId,label){
  trendingLoaded=true;
  currentTrendingCategory=categoryId;
  // Update active pill
  document.querySelectorAll(".t-pill").forEach(p=>p.classList.remove("active"));
  event?.target?.classList.add("active");
  document.getElementById("trendingLoading").style.display="block";
  document.getElementById("trendingGrid").innerHTML="";
  try{
    let url=`https://www.googleapis.com/youtube/v3/videos?part=snippet,contentDetails,statistics,status&chart=mostPopular&maxResults=24&regionCode=US&key=${gak()}`;
    if(categoryId)url+=`&videoCategoryId=${categoryId}`;
    const data=await fetchJSON(url);
    const embeddable=data.items.filter(v=>v.status?.embeddable!==false);
    renderTrending(embeddable);
  }catch(e){
    nextKey();
    document.getElementById("trendingGrid").innerHTML=`<div style="grid-column:1/-1;text-align:center;padding:2rem;color:#ef4444;">Failed to load trending. (${escHtml(e.message)})</div>`;
  }
  document.getElementById("trendingLoading").style.display="none";
}

function renderTrending(items){
  const grid=document.getElementById("trendingGrid");
  grid.innerHTML="";
  items.forEach((v,i)=>{
    const id=v.id;
    const title=v.snippet.title;
    const channel=v.snippet.channelTitle;
    const thumb=v.snippet.thumbnails.medium?.url||v.snippet.thumbnails.default?.url;
    const views=v.statistics?.viewCount?formatViews(v.statistics.viewCount):"";
    const dur=parseDuration(v.contentDetails?.duration||"");
    const div=document.createElement("div");
    div.className="video-card";
    div.innerHTML=`
      <div class="video-thumbnail">
        <img src="${thumb}" alt="" loading="lazy"/>
        <div class="play-overlay"><div class="play-btn-circle">▶</div></div>
        <div class="trending-rank">${i+1}</div>
        ${dur?`<div class="video-duration">${dur}</div>`:""}
      </div>
      <div class="video-info">
        <div class="video-title">${escHtml(title)}</div>
        <div class="video-channel">${escHtml(channel)}</div>
        <div class="video-meta"><span>${views} views</span></div>
      </div>`;
    div.onclick=()=>openVideo(id,title);
    grid.appendChild(div);
  });
}

// ── CARD BUILDERS ──
function makeVideoCard(item){
  const id=item.id.videoId;
  const title=item.snippet.title;
  const channel=item.snippet.channelTitle;
  const thumb=item.snippet.thumbnails.medium?.url||item.snippet.thumbnails.default?.url;
  const date=formatDate(item.snippet.publishedAt);
  const div=document.createElement("div");
  div.className="video-card";
  div.innerHTML=`
    <div class="video-thumbnail">
      <img src="${thumb}" alt="" loading="lazy"/>
      <div class="play-overlay"><div class="play-btn-circle">▶</div></div>
    </div>
    <div class="video-info">
      <div class="video-title">${escHtml(title)}</div>
      <div class="video-channel">${escHtml(channel)}</div>
      <div class="video-meta"><span>${date}</span></div>
    </div>`;
  div.onclick=()=>openVideo(id,title);
  return div;
}

function makePlaylistCard(item){
  const id=item.id.playlistId;
  const title=item.snippet.title;
  const channel=item.snippet.channelTitle;
  const thumb=item.snippet.thumbnails.medium?.url||item.snippet.thumbnails.default?.url;
  const div=document.createElement("div");
  div.className="playlist-card";
  div.innerHTML=`
    <div class="playlist-thumbnail">
      <img src="${thumb}" alt="" loading="lazy"/>
      <div class="play-overlay"><div class="play-btn-circle">▶</div></div>
      <div class="playlist-badge">📋 Playlist</div>
    </div>
    <div class="playlist-info">
      <div class="playlist-title">${escHtml(title)}</div>
      <div class="playlist-meta">${escHtml(channel)}</div>
    </div>`;
  div.onclick=()=>openPlaylist(id,title);
  return div;
}

function makeChannelCard(item){
  const id=item.id.channelId;
  const title=item.snippet.title;
  const desc=item.snippet.description;
  const thumb=item.snippet.thumbnails.medium?.url||item.snippet.thumbnails.default?.url;
  const div=document.createElement("div");
  div.className="video-card";
  div.innerHTML=`<div class="channel-card-inner">
    <img class="channel-avatar-sm" src="${thumb}" alt=""/>
    <div class="channel-card-info">
      <div class="channel-card-name">👤 ${escHtml(title)}</div>
      <div class="channel-card-desc">${escHtml(desc)}</div>
    </div>
  </div>`;
  div.onclick=()=>loadChannelById(id,title);
  return div;
}

// ── CHANNEL ──
async function loadChannelById(channelId,channelTitle){
  showTab("search");
  document.getElementById("searchLoading").style.display="block";
  document.getElementById("searchResultsInner").style.display="none";
  currentQuery=channelTitle; nextPageToken="";
  try{
    const url=`https://www.googleapis.com/youtube/v3/search?part=snippet&channelId=${channelId}&type=video&maxResults=20&order=date&videoEmbeddable=true&key=${gak()}`;
    const data=await fetchJSON(url);
    nextPageToken=data.nextPageToken||"";
    document.getElementById("videoGrid").innerHTML="";
    document.getElementById("searchResultsHeader").style.display="flex";
    document.getElementById("searchResultsTitle").innerHTML=`👤 <em style="color:var(--accent);font-style:normal;">${escHtml(channelTitle)}</em>`;
    data.items.forEach(item=>document.getElementById("videoGrid").appendChild(makeVideoCard(item)));
    document.getElementById("loadMoreWrap").style.display=nextPageToken?"block":"none";
  }catch(e){nextKey();showSearchError("Failed to load channel.");}
  document.getElementById("searchLoading").style.display="none";
  document.getElementById("searchResultsInner").style.display="block";
}

// ── PLAYLIST ──
async function openPlaylist(playlistId,title){
  document.getElementById("videoModal").style.display="flex";
  document.getElementById("modalVideoTitle").textContent=title;
  const container=document.getElementById("videoPlayerContainer");
  const old=document.getElementById("playlistSidebar");
  if(old)old.remove();
  const sidebar=document.createElement("div");
  sidebar.className="playlist-sidebar"; sidebar.id="playlistSidebar";
  sidebar.innerHTML=`
    <div class="playlist-sidebar-header">
      <button class="psb-btn" onclick="shufflePlaylist()">🔀 Shuffle</button>
      <button class="psb-btn${autoplayOn?" active":""}" id="autoplayToggleBtn" onclick="toggleAutoplay()">▶ Auto ${autoplayOn?"ON":"OFF"}</button>
    </div>
    <div id="playlistLoadingSpinner" style="display:flex;"><div class="loading-spinner" style="width:20px;height:20px;margin:0;border-width:2px;"></div><span style="font-size:0.8rem;color:var(--text2);margin-left:6px;">Loading...</span></div>
    <div id="playlistVideos"></div>`;
  container.appendChild(sidebar);
  try{
    const data=await fetchJSON(`https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=${playlistId}&maxResults=50&key=${gak()}`);
    playlistVideos=data.items.map(i=>({
      id:i.snippet.resourceId.videoId,
      title:i.snippet.title,
      channel:i.snippet.videoOwnerChannelTitle||"",
      thumb:i.snippet.thumbnails.default?.url||""
    }));
    document.getElementById("playlistLoadingSpinner").style.display="none";
    renderPlaylistSidebar(0);
    if(playlistVideos.length)openVideo(playlistVideos[0].id,playlistVideos[0].title,playlistVideos,0);
  }catch(e){
    document.getElementById("playlistLoadingSpinner").innerHTML="<span style='color:#ef4444;font-size:0.8rem;'>Failed to load playlist.</span>";
  }
}

function renderPlaylistSidebar(activeIdx){
  document.getElementById("playlistVideos").innerHTML=playlistVideos.map((v,i)=>`
    <div class="playlist-video-item${i===activeIdx?" active":""}" onclick="playPlaylistItem(${i})">
      <img class="playlist-video-thumb" src="${v.thumb}" alt=""/>
      <div class="playlist-video-info">
        <div class="playlist-video-title">${escHtml(v.title)}</div>
        <div class="playlist-video-channel">${escHtml(v.channel)}</div>
      </div>
    </div>`).join("");
}

function playPlaylistItem(idx){
  currentPlaylistIndex=idx;
  const v=playlistVideos[idx];
  setIframeSrc(v.id);
  document.getElementById("modalVideoTitle").textContent=v.title;
  currentVideoId=v.id; currentVideoTitle=v.title;
  renderPlaylistSidebar(idx);
  document.querySelectorAll(".playlist-video-item")[idx]?.scrollIntoView({block:"nearest"});
}

function shufflePlaylist(){
  for(let i=playlistVideos.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [playlistVideos[i],playlistVideos[j]]=[playlistVideos[j],playlistVideos[i]];
  }
  playPlaylistItem(0);
}

function toggleAutoplay(){
  autoplayOn=!autoplayOn;
  const btn=document.getElementById("autoplayToggleBtn");
  if(btn){btn.textContent=`▶ Auto ${autoplayOn?"ON":"OFF"}`;btn.classList.toggle("active",autoplayOn);}
}

// ── VIDEO PLAYER ──
function openVideo(id,title,playlist=[],idx=0){
  currentVideoId=id; currentVideoTitle=title;
  playlistVideos=playlist; currentPlaylistIndex=idx;
  document.getElementById("videoModal").style.display="flex";
  document.getElementById("modalVideoTitle").textContent=title;
  setIframeSrc(id);
  if(!playlist.length){const s=document.getElementById("playlistSidebar");if(s)s.remove();}
}

function setIframeSrc(id){
  document.getElementById("videoIframe").src=`https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
}

function fixWhiteScreen(){
  document.getElementById("videoIframe").src=`https://www.youtube-nocookie.com/embed/${currentVideoId}?autoplay=1&rel=0&vq=hd720&modestbranding=1`;
}

function copyVideoUrl(){
  const url=`https://www.youtube-nocookie.com/embed/${currentVideoId}`;
  navigator.clipboard.writeText(url).then(()=>{
    const btn=document.getElementById("copyUrlBtn");
    btn.textContent="✅ Copied!";
    setTimeout(()=>btn.textContent="🔗 Copy URL",2200);
  });
}

function closeModal(){
  document.getElementById("videoModal").style.display="none";
  document.getElementById("videoIframe").src="";
  playlistVideos=[];
  const s=document.getElementById("playlistSidebar");if(s)s.remove();
}

function modalBackdropClick(e){if(e.target===document.getElementById("videoModal"))closeModal();}
document.addEventListener("keydown",e=>{if(e.key==="Escape")closeModal();});

// ── IMPORT ──
function promptAndImport(){
  const url=prompt("Paste a YouTube video or playlist URL:");
  if(!url)return;
  const vid=url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  const pid=url.match(/[?&]list=([a-zA-Z0-9_-]+)/);
  if(pid)openPlaylist(pid[1],"Imported Playlist");
  else if(vid)openVideo(vid[1],"Imported Video");
  else alert("Couldn't find a video or playlist ID in that URL.");
}

// ── RECENT SEARCHES ──
function saveRecentSearch(q){
  recentSearches=[q,...recentSearches.filter(s=>s!==q)].slice(0,10);
  localStorage.setItem("hms_recent",JSON.stringify(recentSearches));
}
function showRecentSearches(){
  const el=document.getElementById("recentSearches");
  if(!recentSearches.length)return;
  el.innerHTML=`<div class="rs-label">Recent</div>`+recentSearches.map(s=>`
    <div class="search-item" onmousedown="pickRecent('${escHtml(s)}')">
      <span class="search-item-icon">🕒</span>${escHtml(s)}
    </div>`).join("");
  el.classList.add("open");
}
function hideRecentSearches(){setTimeout(()=>document.getElementById("recentSearches").classList.remove("open"),200);}
function pickRecent(q){document.getElementById("searchInput").value=q;currentQuery=q;currentType="video";currentSort="relevance";nextPageToken="";saveRecentSearch(q);performSearch(true);}

// ── NAV ──
function goHome(){
  showTab("home");
  document.getElementById("searchInput").value="";
}

// ── ERROR ──
function showSearchError(msg){
  document.getElementById("videoGrid").innerHTML=`<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#f87171;">${escHtml(msg)}</div>`;
  document.getElementById("searchResultsHeader").style.display="none";
}

// ── HELPERS ──
async function fetchJSON(url){
  const r=await fetch(url);
  const data=await r.json();
  if(data.error)throw new Error(data.error.message);
  return data;
}
function escHtml(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
function formatDate(d){if(!d)return"";return new Date(d).toLocaleDateString("en-US",{year:"numeric",month:"short",day:"numeric"});}
function formatViews(n){n=parseInt(n);if(n>=1e9)return(n/1e9).toFixed(1)+"B";if(n>=1e6)return(n/1e6).toFixed(1)+"M";if(n>=1e3)return(n/1e3).toFixed(0)+"K";return n;}
function parseDuration(iso){
  const m=iso.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
  if(!m)return"";
  const h=parseInt(m[1]||0),min=parseInt(m[2]||0),s=parseInt(m[3]||0);
  if(h)return`${h}:${String(min).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
  return`${min}:${String(s).padStart(2,"0")}`;
}
</script>
